{
  "customer_name": "Customer Name",
  "auth_env_key": "customer_env_key",
  "account_id": 0,
  "days_back": 30,
  "workers": 6,
  "output_file": "outputs/customer_ai_assessment_report.html",

  "fields": {
    "score":      {"key": "your_score_custom_field",       "label": "Call Score"},
    "star":       {"key": "your_star_rating_field",        "label": "Star Rating"},
    "categories": {"key": "your_wrapup_or_topic_field",    "label": "Wrap-Up Code"},
    "highlights": {"key": "your_positives_field",          "label": "Agent Strengths"},
    "concerns":   {"key": "your_negatives_field",          "label": "Coaching Opportunities"},
    "notes":      {"key": "your_summary_text_field",       "label": "Score Notes"}
  },

  "customer_segments": [
    {"id": "existing", "label": "Existing Customer", "short": "EC", "tags": ["ec"]},
    {"id": "new",      "label": "New Customer",      "short": "NC", "tags": ["nc"]}
  ]
